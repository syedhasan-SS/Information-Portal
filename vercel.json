{
  "buildCommand": "npx tsx script/build-vercel.ts",
  "framework": null,
  "functions": {
    "api/index.js": {
      "includeFiles": "dist/server/fonts/**",
      "maxDuration": 300
    }
  },
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        {
          "key": "Content-Security-Policy",
          "value": "frame-ancestors 'self' https://os.joinfleek.com https://*.joinfleek.com"
        },
        {
          "key": "Access-Control-Allow-Origin",
          "value": "https://os.joinfleek.com"
        },
        {
          "key": "Access-Control-Allow-Credentials",
          "value": "true"
        }
      ]
    }
  ],
  "crons": [
    {
      "path": "/api/cron/daily-report",
      "schedule": "30 5 * * 1-5"
    },
    {
      "path": "/api/cron/sync-slack-replies",
      "schedule": "0 6 * * 1-5"
    }
  ],
  "rewrites": [
    {
      "source": "/(.*)",
      "destination": "/api/index"
    }
  ]
}
